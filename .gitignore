# Secrets — never commit
.env
.env.*
!.env.example
secrets/
*.pem
*.key
service-account*.json
gcp-key*.json
dynatrace-token*
*credentials*.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# uv
.uv/
uv.lock

# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.pnpm-store/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# Cloud Build / Docker
.gcloudignore.tmp

# Media artifacts (do not commit large binaries)
*.mp4
*.mov
*.mkv
*.mxf
*.prores
*.wav
*.flac
test-assets/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# Logs
*.log
logs/
