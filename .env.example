# StudioFlow environment — non-secret values only.
# Copy to .env (gitignored) and fill in. Secrets stay in Secret Manager.

# --- GCP ---
PROJECT_ID=studioflow-xx-0000
REGION=us-central1
PUBSUB_TOPIC=studioflow-events
GCS_BUCKET=${PROJECT_ID}-assets
ARTIFACT_REGISTRY_REPO=studioflow

# --- Dynatrace ---
# Tenant URL must be on .apps.dynatrace.com (Platform/Grail), not .live.dynatrace.com.
DT_TENANT=https://YOUR_TENANT.apps.dynatrace.com
# DT_TOKEN is NOT stored here. Fetch with:
#   gcloud secrets versions access latest --secret=dynatrace-token
DT_MCP_URL=${DT_TENANT}/platform-reserved/mcp-gateway/v0.1/servers/dynatrace-mcp/mcp

# --- Gemini / Vertex AI ---
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_THINKING_LEVEL=high
GEMINI_FLASH_MODEL=gemini-3-flash-preview

# --- App ---
DEPLOYMENT_ENV=demo
LOG_LEVEL=INFO
